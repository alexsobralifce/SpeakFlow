# =============================================================
#  SpeakFlow — Variáveis de Ambiente
#  Copie este arquivo para .env.local e preencha os valores:
#    cp .env.example .env.local
# =============================================================

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Google Cloud (opcional) ─────────────────────────────────
# Se não configurado, o sistema usa OpenAI TTS/STT como fallback
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

# ─── Banco de Dados (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/speakflow

# ─── Next.js Auth ────────────────────────────────────────────
NEXTAUTH_SECRET=gere-um-secret-aleatorio-aqui
NEXTAUTH_URL=http://localhost:3000

# ─── Ambiente ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
